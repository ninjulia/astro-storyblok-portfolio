---
import { Image, getImage } from 'astro:assets';
const { title, image, description, link, cta } = Astro.props;
---

<article>
	<figure class="portfolio-display">
		<div class="portfolio-display-image">
			<Image
				src={image.url}
				alt={image.alt}
				inferSize={true}
			/>
		</div>
		<figcaption class="portfolio-display-content surface-1">
			<h3 class="display-3">{title}</h3>
			<p>
				{description}
			</p>
			{
				cta && (
					<a
						class="btn standard m-0 align-self-start"
						href={link}>
						{cta}
					</a>
				)
			}
		</figcaption>
	</figure>
</article>
