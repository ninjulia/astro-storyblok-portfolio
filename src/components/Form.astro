---
import { Icon } from 'astro-icon/components';
import InputField from '../components/elements/InputField.astro';
import TextField from '../components/elements/TextField.astro';
---

<!-- TODO: route form post submission https://docs.netlify.com/forms/setup/ -->
<section
	id="contact"
	class="wrapper img-bg text-left px-2xl py-l m-auto surface-3 align-content-start">
	<div class="content">
		<form
			novalidate
			name="contactForm"
			method="POST"
			action="/#contact"
			data-netlify="true"
			netlify-honeypot="bot-field"
			data-netlify="true"
			data-netlify-recaptcha="true"
			id="contactForm">
			<h2 class="accent mb-m text-center">Contact Stevee</h2>
			<p>Required fields are followed by <span aria-label="required">*</span>.</p>
			<InputField
				label="Enter your name"
				type="text"
				id="name"
				required="true"
				minlength="2"
				placeholder="Your Name"
			/>
			<InputField
				label="Enter your email"
				type="email"
				id="email"
				required="true"
				minlength="8"
				placeholder="Your email"
			/>
			<TextField
				label="Enter your message"
				id="msg"
				required="true"
				minlength="2"
				placeholder="Your message"
			/>
			<!-- <div>
				<label for="email">
					<span
						class="input-title accent text-left"
						aria-label="required"
						>Enter your email *</span
					>
					<input
						type="email"
						name="email"
						id="email"
						required="true"
						minlength="8"
						class="py-xs px-s"
						placeholder="Your email"
					/>
					<span
						aria-hidden="true"
						class="error ps-xs pt-xs m-0"
						aria-live="polite"
					></span>
				</label>
			</div> -->
			<!-- <div>
				<label for="msg">
					<span
						class="input-title accent text-left"
						aria-label="required"
						>Enter your message *</span
					>
					<textarea
						id="msg"
						name="message"
						minlength="2"
						required="true"
						placeholder="Your message"
					></textarea>
					<span
						aria-hidden="true"
						class="error ps-xs pt-xs m-0"
						aria-live="polite"
					></span>
				</label>
			</div> -->
			<div class="hidden">
				<label>
					Don't fill this out if you're human: <input name="bot-field" />
				</label>
			</div>
			<div>
				<input
					type="submit"
					value="Send"
					class="btn standard align-self-center m-auto"
				/>
			</div>
		</form>
	</div>
	<!-- TODO: set this up as a variable within main template -->
	<img
		src="https://images.unsplash.com/photo-1497048679117-1a29644559e3"
		alt=""
	/>
</section>

<dialog class="p-l">
	<button
		autofocus
		class="mb-l">
		<span class="sr-only"> Close</span>
		<Icon
			name=`feather:x-square`
			width={44}
			height={44}
		/>
	</button>
	<p>Your message has been sent!</p>
</dialog>

<style>
	dialog {
		border: none;
	}
	dialog button {
		background-color: transparent;
		border: none;
		padding: 0;
	}
	.hidden {
		visibility: hidden;
		padding: 0;
		margin: 0;
		height: 1px;
		width: 1px;
	}
</style>
<script>
	import '../scripts/form.js';
</script>
