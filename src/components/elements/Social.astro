---
import { Icon } from 'astro-icon/components';
const { platform, username } = Astro.props;
---

<a
	href={`https://www.${platform}.com/${username}`}
	class="social-link"
	rel="noopener"
	title={platform}
	target="_blank"
	aria-label={platform}>
	<Icon
		name=`feather:${platform}`
		width={24}
	/>
</a>
