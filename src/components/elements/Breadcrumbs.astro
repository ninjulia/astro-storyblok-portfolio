---
const { current } = Astro.props;
let trail = current.full_slug.split('/').filter((url) => url !== current.slug);
---

<section
	id="breadcrumbs"
	class="container pt-l px-s pb-m">
	<nav>
		<ul class="m-0 p-0 d-flex flex-row gap-s">
			<li class="breadcrumb">
				<a
					href="/"
					title="home"
					>Home</a
				>
			</li>
			{
				trail[0] !== '' &&
					trail.map((url) => (
						<li class="breadcrumb">
							{url === 'work' ? <a href={`/#${url}/`}>{url}</a> : <a href={`/${url}/`}>{url}</a>}
						</li>
					))
			}

			<li class="breadcrumb">{current.name}</li>
		</ul>
	</nav>
</section>
<style lang="scss">
	.breadcrumb {
		margin-bottom: 0;
		text-transform: capitalize;
		a::after {
			content: ' ›› ';
			font-size: 1em;
		}
	}
</style>
