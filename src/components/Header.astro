---
import HeaderLink from '../components/elements/HeaderLink.astro';
import StandardLinks from '../components/elements/StandardLinks.astro';
import { Image, getImage } from 'astro:assets';
import { useStoryblokApi } from '@storyblok/astro';

const storyblokApi = useStoryblokApi();

const { data } = await storyblokApi.get('cdn/stories/config', {
	version: import.meta.env.DEV ? 'draft' : 'published',
	resolve_links: 'url',
});
const logo = data?.story?.content?.logo;
const headerMenu = data?.story?.content?.header_menu;
const siteName = data?.story?.content?.site_name;
let regex = '[a-z][/]';
let dropdownLinks = headerMenu.filter((menu) => menu.link.cached_url.match(regex));

---

<header id="site-header">
	<div class="wrapper">
		<!-- Skip Links -->
		<a
			href="main-content"
			id="skip-links"
			class="btn standard"
			>Skip to Content
		</a>
		<!-- Main Navigation -->
		<nav
			id="main-site-nav"
			class="d-flex justify-content-space-between align-items-center wrap">
			<a
				href="/"
				title="home page"
				class="main-site-nav-logo m-s">
				<Image
					src={logo.filename}
					alt={siteName}
                    inferSize
                    loading="eager"
				/>
			</a>
			<button
				class="m-s"
				id="main-menu-toggle"
				type="button"
				aria-controls="main-site-nav-links"
				aria-expanded="false">
				<span class="sr-only">Menu</span>
				<svg
					class="menu"
					viewBox="0 0 24 24"
					width="24"
					height="24">
					<line
						class="line top"
						x1="2"
						x2="22"
						y1="2"
						y2="2"
						stroke-width="2"
						stroke-line-cap="round"
						stroke-dasharray="20 20"
						stroke-offset="0">
					</line>
					<line
						class="line middle"
						x1="22"
						x2="2"
						y1="12"
						y2="12"
						stroke-width="2"
						stroke-line-cap="round"
						stroke-dasharray="20 20"
						stroke-offset="0">
					</line>
					<line
						class="line bottom"
						x1="2"
						x2="22"
						y1="22"
						y2="22"
						stroke-width="2"
						stroke-line-cap="round"
						stroke-dasharray="20 20"
						stroke-offset="0">
					</line>
				</svg>
			</button>
			<ul
				id="main-site-nav-links"
				data-visible="false"
				class="nav-links m-0 p-0">
				<!-- show nested links -->
				{
					dropdownLinks && (
						<li class="nav-item dropdown">
							<button
								class="nav-link dropdown-toggle"
								role="button"
								data-toggle="dropdown"
								aria-expanded="false">
                                <!-- TODO: make /work/ dynamic  -->
								Work
							</button>
							<ul
								class="dropdown-menu p-xs m-0"
								aria-hidden="true">
								{dropdownLinks.map((menu) => (
									<HeaderLink
										class="dropdown-item"
										href={`/${menu.link.cached_url}`}>
										{menu.link.story.name}
									</HeaderLink>
								))}
							</ul>
						</li>
					)
				}
				<!-- /show nested links -->
				<StandardLinks />
			</ul>
		</nav>
	</div>
</header>
