---
const today = new Date();
import { SITE_TITLE, LOGO, FOOTER_TEXT } from '../consts';
import { SOCIALS } from '../socials';
import { LINKS } from '../menu';
import Social from '../components/elements/Social.astro';
---

<footer id="site-footer">
	<div class="wrapper d-flex wrap justify-content-space-between gap-s pt-2xl px-s pb-l">
		<img
			src={LOGO}
			alt={SITE_TITLE}
			class="logo"
		/>

		<div class="social-links d-flex wrap justify-content-space-between align-items-center gap-l">
			{
				SOCIALS.map((site) => (
					<Social
						platform={site.name}
						href={site.value}
					/>
				))
			}
		</div>
		<nav class="u-grid">
			<ul class="nav-links m-0 p-0">
				{
					LINKS &&
						LINKS.map((menu) => (
							<li class="nav-item">
								<a
									class="nav-link"
									href={`${menu.value}`}>
									{menu.name}
								</a>
							</li>
						))
				}
			</ul>
		</nav>
		<div class="colophon">
			<p>&copy; {today.getFullYear()} {SITE_TITLE}. All Rights Reserved.</p>
			<p><Fragment set:html={FOOTER_TEXT} /></p>
		</div>
	</div>
</footer>
<script>
	import '../scripts/nav.js';
</script>
