---
import { storyblokEditable, renderRichText } from '@storyblok/astro';
import { Image, getImage } from 'astro:assets';
const { blok } = Astro.props;
const content = renderRichText(blok.content);
---

<article
	class="standard-feature"
	{...storyblokEditable(blok)}>
	<figure class="portfolio-display">
		<div class="portfolio-display-image">
			<Image
				class="standard-feature-image"
				src={blok.image.filename}
				alt={blok.image.alt}
				width="1440"
				height="720"
				densities={[1, 2]}
				widths={[300, 1065, 1470, 1780]}
				sizes={`(min-width: 1520px) 1065px, (min-width: 1480px) calc(1465vw - 20910px), (min-width: 780px) calc(94.41vw - 331px), (min-width: 420px) 100vw, (min-width: 340px) 28.33vw, calc(-1050vw + 3450px)`}
			/>
		</div>
		<figcaption class="portfolio-display-content surface-1">
			<h3 class="display-3">{blok.title}</h3>
			<Fragment set:html={content} />
			{
				blok.link_text !== '' && (
					<a
						class="btn standard m-0 align-self-start"
						href={blok.url}>
						{blok.link_text}
					</a>
				)
			}
		</figcaption>
	</figure>
</article>

<script>
	//don't lazy load images within initial viewport
	let image = document.querySelector('.standard-feature-image');
	let observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			if (entry.isIntersecting) {
				image = entry.target;
				image.setAttribute('loading', 'eager');
				image.setAttribute('decoding', 'auto');
			}
		});
	});
	observer.observe(image);
</script>
